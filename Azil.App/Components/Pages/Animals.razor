@page "/animals"
<MudText Typo="Typo.h4" GutterBottom="true"> Životinje </MudText>
<MudGrid>
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6">Sve životinje</MudText>
            <MudText Typo="Typo.body2">
                Pregled svih životinja evidentiranih u azilu.
            </MudText>
            <MudImage Src="pictures/zivotinje.png"
            Alt="vrste"
            Width="150"
            Class="mb-2" />
        </MudPaper>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Class="mt-3">
            Otvori pregled
        </MudButton>
    </MudItem>

    <MudItem xs="12" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6">Vrste i pasmine</MudText>
            <MudText Typo="Typo.body2">
                Organizacija životinja prema vrstama i pasminama.
            </MudText>
            <MudImage Src="pictures/vrste.png"
                      Alt="vrste"
                      Width="150"
                      Class="mb-2" />
        </MudPaper>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Secondary"
                   Class="mt-2">
            Pogledaj vrste
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Secondary"
                   Class="mt-2">
            Pogledaj pasmine
        </MudButton>
    </MudItem>

    <MudItem xs="12" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6">Smještaj</MudText>
            <MudText Typo="Typo.body2">
                Pregled bokseva, kaveza i drugih smještajnih jedinica.
            </MudText>
            <MudImage Src="pictures/smjestaj.png"
            Alt="smjestaj"
            Width="150"
            Class="mb-2" />
        </MudPaper>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   Class="mt-3">
            Boksevi
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   Class="mt-3">
            Kavezi
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   Class="mt-3">
            Ostalo
        </MudButton>
    </MudItem>
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudImage Src="pictures/dog.png"
                      Alt="smjestaj"
                      Width="150"
                      Class="mb-2" />
            <MudText Typo="Typo.h6">Housing unit</MudText>
            <MudText Typo="Typo.body2">
                Opis.
            </MudText>
           
        </MudPaper>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Warning"
                   Class="mt-3">
            KLIKNI
        </MudButton>
        
    </MudItem>
</MudGrid>



<MudPaper Class="pa-4" Elevation="2">
    <MudImage Src="pictures/dog.png"
              Alt="Pas Rex"
              Width="250"
              Class="mb-2" />

    <MudText Typo="Typo.h6">Rex</MudText>
    <MudText Typo="Typo.body2">
        Pas star 3 godine, miran i druželjubiv.
    </MudText>

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               Class="mt-2">
        Detalji
    </MudButton>
</MudPaper>