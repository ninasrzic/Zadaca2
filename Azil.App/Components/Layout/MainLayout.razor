@inherits LayoutComponentBase

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudText Typo="Typo.h6">AzilEdu</MudText>
        <MudSpacer />
        <MudText Typo="Typo.body2">Sustav za upravljanje azilom</MudText>
    </MudAppBar>

    <MudDrawer Open="true" Elevation="1" Variant="DrawerVariant.Responsive" ClipMode="DrawerClipMode.Always">
        <NavMenu />
